# Vercel / local dev (vercel env pull -> .env.local)

# Supabase (required for login + cloud projects)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Exposed to the browser (Supabase anon key is safe to expose)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI providers
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
LEONARDO_API_KEY=

# Optional: Leonardo model settings
LEONARDO_MODEL_ID=
LEONARDO_MODEL_NAME=
LEONARDO_ALCHEMY=0

# Worker (local PC; not on Vercel)
# APP_BASE_URL=https://your-app.vercel.app
# WORKER_TOKEN=shared-secret-matching-Vercel
# WORKER_VERBOSE=1
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
