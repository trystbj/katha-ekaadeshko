# Vercel / local dev (vercel env pull -> .env.local)

# Supabase (required for login + cloud projects)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Exposed to the browser (Supabase anon key is safe to expose)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI providers
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
LEONARDO_API_KEY=

# Optional: Leonardo model settings
LEONARDO_MODEL_ID=
LEONARDO_MODEL_NAME=
LEONARDO_ALCHEMY=0

