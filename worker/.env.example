# Copy to .env in this folder (worker/.env is gitignored at repo root if needed).
# WORKER_TOKEN must match the WORKER_TOKEN env var on Vercel.

APP_BASE_URL=https://your-app.vercel.app
WORKER_TOKEN=your-shared-secret

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# Optional
# WORKER_VERBOSE=1
# WORKER_ID=my-pc
